{
  "name": "rive-lipsync-previewer",
  "version": "1.1.0",
  "private": true,
  "type": "module",
  "description": "Rive lip sync previewer with browser Rhubarb WASM and optional TTS proxy",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node server.mjs",
    "dev": "node server.mjs",
    "dev:web": "npm --prefix web run dev",
    "dev:web:chrome": "npm --prefix web run dev:chrome",
    "build:web": "npm --prefix web run build",
    "build": "node scripts/build-web.mjs",
    "postinstall": "node scripts/build-web.mjs"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "edge-tts-universal": "^1.4.0"
  }
}
